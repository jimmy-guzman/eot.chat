{
  "$schema": "https://opencode.ai/config.json",
  "formatter": {
    "prettier": {
      "disabled": true
    },
    "oxfmt": {
      "command": ["npx", "oxfmt", "--write", "$FILE"],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".css",
        ".md",
        ".json",
        ".yaml",
        ".yml",
        ".html"
      ]
    }
  },
  "mcp": {
    "excalidraw": {
      "type": "remote",
      "url": "https://mcp.excalidraw.com"
    }
  }
}
